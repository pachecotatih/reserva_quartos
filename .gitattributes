# Auto detect text files and normalize line endings to LF
* text=auto

# Java files
*.java text eol=lf
*.class binary
*.jar binary

# Build files
*.gradle text eol=lf
build.gradle text eol=lf
pom.xml text eol=lf

# Properties and configuration
*.properties text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# IDE
.classpath text eol=lf
.project text eol=lf
.settings/ merge=union
*.iml text eol=lf

# OS
.DS_Store binary
Thumbs.db binary

# Compiled files
*.o binary
*.so binary
*.dylib binary
*.exe binary
*.dll binary
